---
import '../styles.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = 'Lanús Computación - Tecnología B2B y B2C', description = 'Catálogo de tecnología con precios mayoristas y minoristas en Lanús', image } = Astro.props;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFE600" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://http2.mlstatic.com" />
    <link rel="dns-prefetch" href="https://http2.mlstatic.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Schema.org WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Lanús Computación",
      "url": "https://lanuscomputacion.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://lanuscomputacion.com/busqueda/{search_term_string}",
        "query": "required name=search_term_string"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp floating button -->
    <a href="https://wa.me/5491153323937" target="_blank" rel="noopener noreferrer"
       class="fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20ba5a] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all hover:scale-110"
       aria-label="WhatsApp">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <script>
      const CART_KEY = 'lanuscom-cart';

      function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); }
        catch { return []; }
      }

      function saveCart(cart) {
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        window.dispatchEvent(new CustomEvent('cart-update'));
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-add-to-cart]');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();

        const id = btn.getAttribute('data-add-to-cart')!;
        const title = btn.getAttribute('data-title') || '';
        const price = Number(btn.getAttribute('data-price') || 0);
        const image = btn.getAttribute('data-image') || '';
        const slug = btn.getAttribute('data-slug') || '';

        const cart = getCart();
        const existing = cart.find((i) => i.product_id === id);
        if (existing) {
          existing.quantity += 1;
        } else {
          cart.push({ product_id: id, title, price, quantity: 1, thumbnail: image, slug });
        }
        saveCart(cart);

        const original = btn.textContent;
        btn.textContent = '¡Agregado!';
        btn.classList.add('bg-green-500', 'text-white', 'border-green-500');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('bg-green-500', 'text-white', 'border-green-500');
        }, 1500);
      });
    </script>
  </body>
</html>
