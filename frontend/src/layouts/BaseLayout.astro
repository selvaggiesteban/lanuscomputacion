---
import '../styles.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = 'Lanús Computación - Tecnología B2B y B2C', description = 'Catálogo de tecnología con precios mayoristas y minoristas en Lanús', image } = Astro.props;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFE600" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://http2.mlstatic.com" />
    <link rel="dns-prefetch" href="https://http2.mlstatic.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Schema.org WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Lanús Computación",
      "url": "https://lanuscomputacion.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://lanuscomputacion.com/busqueda/{search_term_string}",
        "query": "required name=search_term_string"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      const CART_KEY = 'lanuscom-cart';

      function getCart() {
        try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); }
        catch { return []; }
      }

      function saveCart(cart) {
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        window.dispatchEvent(new CustomEvent('cart-update'));
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-add-to-cart]');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();

        const id = btn.getAttribute('data-add-to-cart')!;
        const title = btn.getAttribute('data-title') || '';
        const price = Number(btn.getAttribute('data-price') || 0);
        const image = btn.getAttribute('data-image') || '';
        const slug = btn.getAttribute('data-slug') || '';

        const cart = getCart();
        const existing = cart.find((i) => i.product_id === id);
        if (existing) {
          existing.quantity += 1;
        } else {
          cart.push({ product_id: id, title, price, quantity: 1, thumbnail: image, slug });
        }
        saveCart(cart);

        const original = btn.textContent;
        btn.textContent = '¡Agregado!';
        btn.classList.add('bg-green-500', 'text-white', 'border-green-500');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('bg-green-500', 'text-white', 'border-green-500');
        }, 1500);
      });
    </script>
  </body>
</html>
