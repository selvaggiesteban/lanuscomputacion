---
export interface Props {
  rating: number;
  count?: number;
}

const { rating, count } = Astro.props;
const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.3;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---

<div class="flex items-center gap-1">
  <div class="flex text-ml-star">
    {[...Array(fullStars)].map(() => (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#FFD700" stroke="#FFD700" stroke-width="1">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26" />
      </svg>
    ))}
    {hasHalf && (
      <svg width="12" height="12" viewBox="0 0 24 24" stroke="#FFD700" stroke-width="1">
        <defs>
          <linearGradient id="halfStar">
            <stop offset="50%" stop-color="#FFD700" />
            <stop offset="50%" stop-color="#E0E0E0" />
          </linearGradient>
        </defs>
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26" fill="url(#halfStar)" />
      </svg>
    )}
    {[...Array(emptyStars)].map(() => (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#E0E0E0" stroke="#E0E0E0" stroke-width="1">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26" />
      </svg>
    ))}
  </div>
  {count !== undefined && (
    <span class="text-xs text-ml-text-muted">({count})</span>
  )}
</div>
