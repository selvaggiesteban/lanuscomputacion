---
import Logo from '../../components/ui/Logo.astro';
import MegaMenu from './MegaMenu.astro';
import CartIcon from '../../components/cart/CartIcon.tsx';
import { getCategories, getSubcategories } from '../../lib/d1';

const db = (Astro.locals as any).runtime?.env?.DB;
let mobileCategories: any[] = [];

if (db) {
  const topCats = await getCategories(db);
  mobileCategories = await Promise.all(
    topCats.map(async (cat: any) => {
      const subs = await getSubcategories(db, cat.id);
      return { ...cat, subcategories: subs };
    })
  );
}
---

<header class="bg-white border-b sticky top-0 z-50">
  <!-- Top bar -->
  <div class="ml-container flex items-center justify-between h-header">
    <div class="flex items-center gap-4 flex-1">
      <!-- Hamburger (mobile) -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 -ml-2" aria-label="Menú">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>

      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Lanús Computación inicio">
        <Logo />
      </a>

      <!-- Search bar -->
      <div class="hidden sm:flex flex-1 max-w-2xl mx-4">
        <div class="relative w-full">
          <input
            type="text"
            class="w-full h-10 pl-4 pr-12 text-sm border rounded-full bg-ml-bg focus:bg-white focus:border-ml-blue focus:outline-none transition-colors"
            placeholder="Buscar productos, marcas y más..."
            aria-label="Buscar"
          />
          <button class="absolute right-1 top-1/2 -translate-y-1/2 p-2 text-ml-blue hover:text-ml-blue-hover" aria-label="Buscar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-3 text-sm text-ml-text-secondary">
      <!-- PC / Info -->
      <a href="/login" class="hidden md:flex items-center gap-1 hover:text-ml-blue transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
          <line x1="8" y1="21" x2="16" y2="21" />
          <line x1="12" y1="17" x2="12" y2="21" />
        </svg>
        <span class="hidden lg:inline">PC / Info</span>
      </a>

      <!-- Perfil (shown when logged out) -->
      <a href="/login" id="login-link" class="flex items-center gap-1 hover:text-ml-blue transition-colors" title="Mi perfil">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span class="hidden lg:inline">Iniciar sesión</span>
      </a>

      <!-- User menu (shown when logged in) -->
      <div id="user-menu" class="hidden relative">
        <button id="user-menu-btn" class="flex items-center gap-1 hover:text-ml-blue transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
          <span id="user-name" class="hidden lg:inline"></span>
        </button>
        <div id="user-dropdown" class="hidden absolute right-0 top-full mt-2 bg-white border rounded shadow-lg py-2 min-w-[160px] z-50">
          <a href="/perfil" class="block px-4 py-2 text-sm hover:bg-gray-50">Mi perfil</a>
          <a href="/compras" class="block px-4 py-2 text-sm hover:bg-gray-50">Mis compras</a>
          <a href="/favoritos" class="block px-4 py-2 text-sm hover:bg-gray-50">Favoritos</a>
          <hr class="my-1">
          <button id="logout-btn" class="block w-full text-left px-4 py-2 text-sm hover:bg-gray-50 text-red-600">Cerrar sesión</button>
        </div>
      </div>

      <!-- Compras -->
      <a href="/compras" class="flex items-center gap-1 hover:text-ml-blue transition-colors" title="Mis compras">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
      </a>

      <!-- Favoritos -->
      <a href="/favoritos" class="hover:text-ml-blue transition-colors" title="Favoritos">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>
      </a>

      <!-- Notificaciones -->
      <button class="hover:text-ml-blue transition-colors relative" title="Notificaciones" aria-label="Notificaciones">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
        <span class="absolute -top-1 -right-1 w-4 h-4 bg-ml-blue text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
      </button>

      <!-- Carrito -->
      <CartIcon client:load />
    </div>
  </div>

  <!-- Mega Menu -->
  <MegaMenu />
</header>

<!-- Mobile drawer -->
<div id="mobile-drawer" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-black/50 animate-fade-in"></div>
  <!-- Panel -->
  <div id="mobile-panel" class="absolute left-0 top-0 h-full w-80 bg-white shadow-drawer animate-slide-in overflow-y-auto">
    <div class="flex items-center justify-between p-4 border-b">
      <span class="font-semibold text-ml-text">Menú</span>
      <button id="mobile-close-btn" class="p-1 hover:text-ml-blue transition-colors" aria-label="Cerrar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
    <nav class="py-2">
      <a href="/" class="block px-4 py-3 text-sm text-ml-text hover:bg-gray-50 hover:text-ml-blue transition-colors">Inicio</a>
      {mobileCategories.map((cat) => (
        <details class="group">
          <summary class="flex items-center justify-between px-4 py-3 text-sm text-ml-text hover:bg-gray-50 cursor-pointer list-none">
            <span>{cat.picture} {cat.name}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-open:rotate-90">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </summary>
          <div class="bg-gray-50 py-1">
            <a href={`/categoria/${cat.slug}`} class="block px-8 py-2 text-xs text-ml-blue font-medium hover:bg-gray-100 transition-colors">
              Ver todos →
            </a>
            {cat.subcategories.map((sub: any) => (
              <a href={`/categoria/${sub.slug}`} class="block px-8 py-2 text-sm text-ml-text-secondary hover:bg-gray-100 hover:text-ml-blue transition-colors">
                {sub.picture} {sub.name}
              </a>
            ))}
          </div>
        </details>
      ))}
      <hr class="my-2">
      <a href="/ofertas" class="block px-4 py-3 text-sm text-ml-green font-semibold hover:bg-gray-50 transition-colors">Ofertas</a>
      <a href="/categoria/todas" class="block px-4 py-3 text-sm text-ml-text hover:bg-gray-50 hover:text-ml-blue transition-colors">Todas las categorías</a>
      <hr class="my-2">
      <a href="/login" class="block px-4 py-3 text-sm text-ml-text hover:bg-gray-50 hover:text-ml-blue transition-colors">Iniciar sesión</a>
      <a href="/register" class="block px-4 py-3 text-sm text-ml-text hover:bg-gray-50 hover:text-ml-blue transition-colors">Crear cuenta</a>
    </nav>
  </div>
</div>

<script>
  // Mobile drawer
  const drawer = document.getElementById('mobile-drawer');
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const backdrop = document.getElementById('mobile-backdrop');

  function openDrawer() { drawer?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeDrawer() { drawer?.classList.add('hidden'); document.body.style.overflow = ''; }

  openBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Check auth state and update header
  async function checkAuth() {
    try {
      const res = await fetch('/api/auth/me');
      const data = await res.json();

      const loginLink = document.getElementById('login-link');
      const userMenu = document.getElementById('user-menu');
      const userName = document.getElementById('user-name');
      const userDropdown = document.getElementById('user-dropdown');
      const userMenuBtn = document.getElementById('user-menu-btn');
      const logoutBtn = document.getElementById('logout-btn');

      if (data.user) {
        // Logged in
        loginLink?.classList.add('hidden');
        userMenu?.classList.remove('hidden');
        if (userName) userName.textContent = data.user.name;

        // Toggle dropdown
        userMenuBtn?.addEventListener('click', () => {
          userDropdown?.classList.toggle('hidden');
        });

        // Logout
        logoutBtn?.addEventListener('click', async () => {
          await fetch('/api/auth/logout', { method: 'POST' });
          window.location.href = '/';
        });

        // Close dropdown on outside click
        document.addEventListener('click', (e) => {
          if (!userMenuBtn?.contains(e.target as Node) && !userDropdown?.contains(e.target as Node)) {
            userDropdown?.classList.add('hidden');
          }
        });
      } else {
        // Logged out
        loginLink?.classList.remove('hidden');
        userMenu?.classList.add('hidden');
      }
    } catch (err) {
      console.error('Auth check failed:', err);
    }
  }

  checkAuth();
</script>
