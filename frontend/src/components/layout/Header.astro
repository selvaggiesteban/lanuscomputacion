---
import Logo from '../../components/ui/Logo.astro';
import MegaMenu from './MegaMenu.astro';
---

<header class="bg-white border-b sticky top-0 z-50">
  <!-- Top bar -->
  <div class="ml-container flex items-center justify-between h-header">
    <div class="flex items-center gap-4 flex-1">
      <!-- Hamburger (mobile) -->
      <button class="lg:hidden p-2 -ml-2" aria-label="Menú">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>

      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Lanús Computación inicio">
        <Logo />
      </a>

      <!-- Search bar -->
      <div class="hidden sm:flex flex-1 max-w-2xl mx-4">
        <div class="relative w-full">
          <input
            type="text"
            class="w-full h-10 pl-4 pr-12 text-sm border rounded-full bg-ml-bg focus:bg-white focus:border-ml-blue focus:outline-none transition-colors"
            placeholder="Buscar productos, marcas y más..."
            aria-label="Buscar"
          />
          <button class="absolute right-1 top-1/2 -translate-y-1/2 p-2 text-ml-blue hover:text-ml-blue-hover" aria-label="Buscar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-3 text-sm text-ml-text-secondary">
      <!-- PC / Info -->
      <a href="/login" class="hidden md:flex items-center gap-1 hover:text-ml-blue transition-colors">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
          <line x1="8" y1="21" x2="16" y2="21" />
          <line x1="12" y1="17" x2="12" y2="21" />
        </svg>
        <span class="hidden lg:inline">PC / Info</span>
      </a>

      <!-- Perfil -->
      <a href="/perfil" class="flex items-center gap-1 hover:text-ml-blue transition-colors" title="Mi perfil">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span class="hidden lg:inline">Perfil</span>
      </a>

      <!-- Compras -->
      <a href="/compras" class="flex items-center gap-1 hover:text-ml-blue transition-colors" title="Mis compras">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
      </a>

      <!-- Favoritos -->
      <a href="/favoritos" class="hover:text-ml-blue transition-colors" title="Favoritos">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
        </svg>
      </a>

      <!-- Notificaciones -->
      <button class="hover:text-ml-blue transition-colors relative" title="Notificaciones" aria-label="Notificaciones">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
        <span class="absolute -top-1 -right-1 w-4 h-4 bg-ml-blue text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
      </button>

      <!-- Carrito -->
      <a href="/carrito" class="flex items-center gap-1 hover:text-ml-blue transition-colors relative" title="Carrito">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="9" cy="21" r="1" />
          <circle cx="20" cy="21" r="1" />
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
        </svg>
        <span class="hidden lg:inline">Carrito</span>
        <span class="absolute -top-2 -right-2 w-4 h-4 bg-ml-blue text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
      </a>
    </div>
  </div>

  <!-- Mega Menu -->
  <MegaMenu />
</header>
