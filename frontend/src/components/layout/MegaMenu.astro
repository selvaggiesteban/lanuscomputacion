---
import { getCategories, getSubcategories } from '../../lib/d1';

const db = (Astro.locals as any).runtime?.env?.DB;
let categories: any[] = [];

if (db) {
  const topCategories = await getCategories(db);
  categories = await Promise.all(
    topCategories.map(async (cat) => {
      const subs = await getSubcategories(db, cat.id);
      return { ...cat, subcategories: subs };
    })
  );
}
---

<nav class="hidden lg:block bg-white border-t" aria-label="Categorías principales">
  <div class="ml-container">
    <ul class="flex items-center h-megamenu -ml-4">
      <li class="relative group">
        <a href="/categoria/todas" class="flex items-center gap-1 px-3 py-2 text-sm text-ml-text-secondary hover:text-ml-blue transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          Categorías
        </a>
      </li>
      {categories.map((cat) => (
        <li class="relative group">
          <a
            href={`/categoria/${cat.slug}`}
            class="block px-3 py-2 text-sm text-ml-text-secondary hover:text-ml-blue transition-colors whitespace-nowrap"
          >
            {cat.picture} {cat.name}
          </a>
          <!-- Dropdown -->
          <div class="absolute top-full left-0 hidden group-hover:block bg-white shadow-megamenu border-t-2 border-ml-yellow rounded-b min-w-[600px] p-4 animate-fade-in z-50">
            <div class="grid grid-cols-3 gap-6">
              {cat.subcategories.map((sub) => (
                <a
                  href={`/categoria/${sub.slug}`}
                  class="block text-sm text-ml-text hover:text-ml-blue transition-colors py-1"
                >
                  {sub.picture} {sub.name}
                  {sub.total_items > 0 && (
                    <span class="text-xs text-ml-text-secondary ml-1">({sub.total_items})</span>
                  )}
                </a>
              ))}
            </div>
            <a
              href={`/categoria/${cat.slug}`}
              class="block mt-3 pt-3 border-t text-xs text-ml-blue font-medium hover:text-ml-blue-hover"
            >
              Ver todos los productos de {cat.name} →
            </a>
          </div>
        </li>
      ))}

      <!-- Ofertas -->
      <li>
        <a href="/ofertas" class="block px-3 py-2 text-sm text-ml-green font-semibold hover:text-green-700 transition-colors whitespace-nowrap">
          Ofertas
        </a>
      </li>
    </ul>
  </div>
</nav>
