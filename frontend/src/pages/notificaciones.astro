---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Notificaciones | Lanús Computación">
  <div class="ml-container py-6">
    <h1 class="text-xl font-semibold text-ml-text mb-6">Notificaciones</h1>

    <div id="notifications-loading" class="text-center py-16 text-ml-text-muted">
      <p>Cargando notificaciones...</p>
    </div>

    <div id="notifications-empty" class="hidden bg-white rounded shadow-card p-8 text-center text-ml-text-muted">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-4 opacity-30">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
      </svg>
      <p class="text-lg font-medium text-ml-text mb-2">No tenés notificaciones</p>
      <p class="text-sm">Las notificaciones sobre tus pedidos y promociones aparecerán acá</p>
    </div>

    <div id="notifications-list" class="hidden space-y-3"></div>
  </div>
</BaseLayout>

<script>
  const loading = document.getElementById('notifications-loading')!;
  const empty = document.getElementById('notifications-empty')!;
  const list = document.getElementById('notifications-list')!;

  async function loadNotifications() {
    try {
      const meRes = await fetch('/api/auth/me');
      const meData = await meRes.json();

      if (!meData.user) {
        loading.classList.add('hidden');
        empty.classList.remove('hidden');
        empty.querySelector('p')!.textContent = 'Iniciá sesión para ver tus notificaciones';
        return;
      }

      const res = await fetch('/api/notifications');
      const data = await res.json();
      loading.classList.add('hidden');

      if (!data.notifications || data.notifications.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      list.classList.remove('hidden');
      list.innerHTML = data.notifications.map((n: any) => `
        <div class="bg-white rounded shadow-card p-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 bg-ml-blue-light rounded-full flex items-center justify-center flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm text-ml-text">${n.title || 'Notificación'}</p>
              <p class="text-xs text-ml-text-muted mt-1">${n.message || ''}</p>
              <p class="text-xs text-ml-text-muted mt-2">${new Date(n.created_at).toLocaleDateString('es-AR')}</p>
            </div>
          </div>
        </div>
      `).join('');
    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  loadNotifications();
</script>
