---
import BaseLayout from '../../layouts/BaseLayout.astro';

const db = Astro.locals.runtime.env.DB;
const page = Number(Astro.url.searchParams.get('page') || 1);
const status = Astro.url.searchParams.get('status') || '';
const limit = 20;
const offset = (page - 1) * limit;

let orders: any[] = [];
let total = 0;

if (status) {
  const { results } = await db.prepare("SELECT * FROM orders WHERE status = ? ORDER BY created_at DESC LIMIT ? OFFSET ?").bind(status, limit, offset).all();
  orders = results;
  const countResult = await db.prepare("SELECT COUNT(*) as count FROM orders WHERE status = ?").bind(status).first<{ count: number }>();
  total = countResult?.count ?? 0;
} else {
  const { results } = await db.prepare("SELECT * FROM orders ORDER BY created_at DESC LIMIT ? OFFSET ?").bind(limit, offset).all();
  orders = results;
  const countResult = await db.prepare("SELECT COUNT(*) as count FROM orders").first<{ count: number }>();
  total = countResult?.count ?? 0;
}

const totalPages = Math.ceil(total / limit);

const statusLabels: Record<string, string> = {
  pending: 'Pendiente', paid: 'Pagado', processing: 'Procesando',
  shipped: 'Enviado', delivered: 'Entregado', cancelled: 'Cancelado',
};
const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800', paid: 'bg-green-100 text-green-800',
  processing: 'bg-blue-100 text-blue-800', shipped: 'bg-purple-100 text-purple-800',
  delivered: 'bg-green-100 text-green-800', cancelled: 'bg-red-100 text-red-800',
};
---

<BaseLayout title="Órdenes | Admin - Lanús Computación">
  <div class="ml-container py-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-semibold text-ml-text">Órdenes</h1>
      <a href="/admin" class="text-sm text-ml-blue hover:underline">← Volver</a>
    </div>

    <div class="bg-white rounded shadow-card p-4 mb-6">
      <div class="flex gap-3 flex-wrap">
        <a href="/admin/orders" class={`px-3 py-1 rounded text-sm ${!status ? 'bg-ml-blue text-white' : 'bg-gray-100 hover:bg-gray-200'}`}>Todas</a>
        {Object.entries(statusLabels).map(([key, label]) => (
          <a href={`/admin/orders?status=${key}`} class={`px-3 py-1 rounded text-sm ${status === key ? 'bg-ml-blue text-white' : 'bg-gray-100 hover:bg-gray-200'}`}>{label}</a>
        ))}
      </div>
    </div>

    <div class="bg-white rounded shadow-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b">
            <tr>
              <th class="text-left p-3 font-medium text-ml-text">Pedido</th>
              <th class="text-left p-3 font-medium text-ml-text">Cliente</th>
              <th class="text-right p-3 font-medium text-ml-text">Total</th>
              <th class="text-center p-3 font-medium text-ml-text">Estado</th>
              <th class="text-left p-3 font-medium text-ml-text">Fecha</th>
              <th class="text-center p-3 font-medium text-ml-text">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            {orders.map((o: any) => (
              <tr class="hover:bg-gray-50">
                <td class="p-3 font-mono text-xs text-ml-text">#{o.id.slice(0, 8)}...</td>
                <td class="p-3">
                  <p class="text-ml-text">{o.customer_name}</p>
                  <p class="text-xs text-ml-text-muted">{o.customer_email}</p>
                </td>
                <td class="p-3 text-right font-medium text-ml-text">${o.total?.toLocaleString('es-AR')}</td>
                <td class="p-3 text-center">
                  <select class={`status-select text-xs font-medium rounded px-2 py-1 border-0 ${statusColors[o.status] || 'bg-gray-100'}`} data-id={o.id}>
                    {Object.entries(statusLabels).map(([key, label]) => (
                      <option value={key} selected={o.status === key}>{label}</option>
                    ))}
                  </select>
                </td>
                <td class="p-3 text-ml-text-muted text-xs">{new Date(o.created_at).toLocaleDateString('es-AR')}</td>
                <td class="p-3 text-center text-xs">
                  <a href={`/compras?order=${o.id}`} class="text-ml-blue hover:underline">Ver</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {totalPages > 1 && (
        <div class="p-4 border-t flex items-center justify-between">
          <p class="text-sm text-ml-text-muted">Mostrando {offset + 1}-{Math.min(offset + limit, total)} de {total}</p>
          <div class="flex gap-2">
            {page > 1 && <a href={`/admin/orders?page=${page - 1}${status ? `&status=${status}` : ''}`} class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Anterior</a>}
            {page < totalPages && <a href={`/admin/orders?page=${page + 1}${status ? `&status=${status}` : ''}`} class="px-3 py-1 border rounded text-sm hover:bg-gray-50">Siguiente</a>}
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.status-select').forEach(select => {
    select.addEventListener('change', async (e) => {
      const id = (e.target as HTMLElement).dataset.id;
      const status = (e.target as HTMLSelectElement).value;
      await fetch('/api/admin/orders', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status }),
      });
      location.reload();
    });
  });
</script>
