---
import BaseLayout from '../../layouts/BaseLayout.astro';

const db = Astro.locals.runtime.env.DB;

// Get B2B customers grouped by status
const [pending, approved, rejected] = await Promise.all([
  db.prepare("SELECT id, email, name, phone, b2b_status, created_at FROM customers WHERE is_b2b = 1 AND b2b_status = 'pending' ORDER BY created_at DESC").all(),
  db.prepare("SELECT id, email, name, phone, b2b_status, created_at FROM customers WHERE is_b2b = 1 AND b2b_status = 'approved' ORDER BY created_at DESC").all(),
  db.prepare("SELECT id, email, name, phone, b2b_status, created_at FROM customers WHERE is_b2b = 1 AND b2b_status = 'rejected' ORDER BY created_at DESC").all(),
]);
---

<BaseLayout title="Gestión B2B | Admin">
  <div class="ml-container py-6">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-ml-blue hover:underline text-sm">← Volver al Dashboard</a>
        <h1 class="text-xl font-semibold text-ml-text">Gestión de Cuentas B2B</h1>
      </div>
      <div class="flex gap-2 text-sm">
          <span class="px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full">{pending.results.length} pendientes</span>
          <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full">{approved.results.length} aprobadas</span>
          <span class="px-3 py-1 bg-red-100 text-red-800 rounded-full">{rejected.results.length} rechazadas</span>
        </div>
      </div>

      <!-- Pending -->
      <div class="bg-white rounded shadow-card mb-6">
        <div class="p-4 border-b bg-yellow-50">
          <h2 class="font-medium text-ml-text">Pendientes de Aprobación</h2>
        </div>
        <div class="p-4">
          {pending.results.length > 0 ? (
            <div class="space-y-3" id="b2b-pending">
              {(pending.results as any[]).map((c) => (
                <div class="flex items-center justify-between p-4 border rounded-lg" data-id={c.id}>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-ml-text">{c.name}</p>
                    <p class="text-xs text-ml-text-muted">{c.email} · {c.phone}</p>
                    <p class="text-xs text-ml-text-muted">Solicitó: {new Date(c.created_at).toLocaleDateString('es-AR')}</p>
                  </div>
                  <div class="flex gap-2 ml-4">
                    <button class="b2b-approve px-3 py-1 bg-green-600 text-white text-sm rounded hover:bg-green-700" data-id={c.id}>
                      Aprobar
                    </button>
                    <button class="b2b-reject px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700" data-id={c.id}>
                      Rechazar
                    </button>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-ml-text-muted text-center py-4">No hay solicitudes pendientes</p>
          )}
        </div>
      </div>

      <!-- Approved -->
      <div class="bg-white rounded shadow-card mb-6">
        <div class="p-4 border-b bg-green-50">
          <h2 class="font-medium text-ml-text">Cuentas Aprobadas</h2>
        </div>
        <div class="p-4">
          {approved.results.length > 0 ? (
            <div class="space-y-2">
              {(approved.results as any[]).map((c) => (
                <div class="flex items-center justify-between p-3 border rounded-lg">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-ml-text">{c.name}</p>
                    <p class="text-xs text-ml-text-muted">{c.email} · {c.phone}</p>
                  </div>
                  <span class="text-xs text-green-600 font-medium">Aprobado</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-ml-text-muted text-center py-4">No hay cuentas aprobadas</p>
          )}
        </div>
      </div>

      <!-- Rejected -->
      <div class="bg-white rounded shadow-card">
        <div class="p-4 border-b bg-red-50">
          <h2 class="font-medium text-ml-text">Cuentas Rechazadas</h2>
        </div>
        <div class="p-4">
          {rejected.results.length > 0 ? (
            <div class="space-y-2">
              {(rejected.results as any[]).map((c) => (
                <div class="flex items-center justify-between p-3 border rounded-lg">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-ml-text">{c.name}</p>
                    <p class="text-xs text-ml-text-muted">{c.email} · {c.phone}</p>
                  </div>
                  <span class="text-xs text-red-600 font-medium">Rechazado</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-ml-text-muted text-center py-4">No hay cuentas rechazadas</p>
          )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  async function updateB2BStatus(id: number, status: string) {
    try {
      const res = await fetch('/api/admin/b2b', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, b2b_status: status }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('Error al actualizar');
      }
    } catch {
      alert('Error de conexión');
    }
  }

  document.querySelectorAll('.b2b-approve').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.id);
      updateB2BStatus(id, 'approved');
    });
  });

  document.querySelectorAll('.b2b-reject').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = Number((btn as HTMLElement).dataset.id);
      updateB2BStatus(id, 'rejected');
    });
  });
</script>
