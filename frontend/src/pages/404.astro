---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada - Lanús Computación">
  <div class="ml-container py-16 text-center">
    <div class="max-w-md mx-auto">
      <div class="text-6xl mb-4 text-ml-yellow">!</div>
      <h1 class="text-2xl font-bold text-ml-text mb-2">Página no encontrada</h1>
      <p class="text-ml-text-secondary mb-6">
        La página que buscas no existe o fue movida.
      </p>
      <a href="/" class="ml-btn-primary inline-block">
        Volver al inicio
      </a>
    </div>
  </div>
</BaseLayout>
