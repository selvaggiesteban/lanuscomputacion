---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Iniciar sesión | Lanús Computación">
  <div class="ml-container py-8">
    <div class="max-w-md mx-auto">
      <div class="bg-white rounded shadow-card p-8">
        <div class="text-center mb-6">
          <h1 class="text-xl font-semibold text-ml-text">¡Hola!</h1>
          <p class="text-sm text-ml-text-secondary mt-1">Ingresá tu email y contraseña</p>
        </div>

        <div id="error-message" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded text-sm text-red-700"></div>

        <form id="login-form" class="space-y-4">
          <div>
            <input
              type="email"
              name="email"
              placeholder="Correo electrónico"
              class="ml-input w-full h-12"
              required
            />
          </div>
          <div>
            <input
              type="password"
              name="password"
              placeholder="Contraseña"
              class="ml-input w-full h-12"
              required
            />
          </div>

          <button type="submit" class="ml-btn-primary w-full h-12 text-base">
            Continuar
          </button>
        </form>

        <div class="my-6 flex items-center gap-3 text-sm text-ml-text-muted">
          <div class="flex-1 h-px bg-ml-border" />
          <span>o</span>
          <div class="flex-1 h-px bg-ml-border" />
        </div>

        <!-- Social Login -->
        <div class="space-y-3">
          <button id="google-login" class="w-full h-12 flex items-center justify-center gap-3 border border-ml-border rounded hover:bg-gray-50 transition-colors text-sm font-medium">
            <svg width="20" height="20" viewBox="0 0 48 48">
              <path fill="#4285F4" d="M23.49 12.3c3.68 0 6.45 1.6 7.93 2.97l5.85-5.83C33.78 5.7 29.25 4 23.49 4 15.3 4 8.27 8.82 5 15.78l6.72 5.24c1.9-4.15 5.9-6.72 11.77-6.72z"/>
              <path fill="#34A853" d="M4 24c0 1.82.27 3.58.78 5.24L11.27 24c-.32-1.03-.5-2.13-.5-3.3s.18-2.27.5-3.3L4.78 12.3C4.27 13.96 4 15.82 4 24z"/>
              <path fill="#FBBC05" d="M23.49 36.3c-5.87 0-9.87-2.57-11.77-6.72L5.27 34.7C8.27 41.18 15.3 46 23.49 46c5.7 0 11.44-2.2 15.5-6.36l-6.7-5.3c-2.16 1.66-5.08 2.96-8.8 2.96z"/>
              <path fill="#EA4335" d="M46 24c0-1.84-.3-3.62-.88-5.28H23.5v9.56h12.87c-.55 2.98-2.17 5.42-4.58 7.02l6.7 5.3C43.05 38.6 46 32 46 24z"/>
            </svg>
            Continuar con Google
          </button>
        </div>

        <p class="text-center mt-6 text-xs text-ml-text-muted">
          ¿No tenés cuenta?
          <a href="/register" class="ml-link"> Registrate</a>
        </p>

        <p class="text-center mt-2 text-xs text-ml-text-muted">
          Al continuar, aceptás los
          <a href="#" class="ml-link"> Términos y Condiciones</a> y la
          <a href="#" class="ml-link"> Política de Privacidad</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message')!;
  const googleBtn = document.getElementById('google-login')!;

  // Show error from URL params (e.g., ?error=google_cancelled)
  const params = new URLSearchParams(window.location.search);
  const errorParam = params.get('error');
  if (errorParam) {
    const messages: Record<string, string> = {
      google_cancelled: 'Inicio de sesión con Google cancelado.',
      google_token_failed: 'Error al autenticar con Google.',
      google_failed: 'Error al conectar con Google.',
    };
    errorDiv.textContent = messages[errorParam] || 'Error al iniciar sesión con Google';
    errorDiv.classList.remove('hidden');
    window.history.replaceState({}, '', '/login');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorDiv.textContent = data.error || 'Error al iniciar sesión';
        errorDiv.classList.remove('hidden');
        return;
      }

      window.location.href = '/';
    } catch (err) {
      errorDiv.textContent = 'Error de conexión';
      errorDiv.classList.remove('hidden');
    }
  });

  googleBtn?.addEventListener('click', () => {
    window.location.href = '/api/auth/google';
  });
</script>
