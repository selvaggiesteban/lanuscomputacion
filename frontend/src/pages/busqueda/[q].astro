---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';

export async function getStaticPaths() {
  return [{ params: { q: 'celulares' } }, { params: { q: 'notebooks' } }];
}

const { q } = Astro.params;

const results = [
  { id: '1', title: 'iPhone 15 Pro Max 256GB', price: 2199999, originalPrice: 2499999, discount: 12, image: 'https://via.placeholder.com/200', slug: 'iphone-15-pro-max', rating: 4.7, reviewsCount: 89, freeShipping: true, installments: { count: 6, value: 366666 } },
  { id: '2', title: 'Samsung Galaxy S24 Ultra 512GB', price: 1799999, originalPrice: 1999999, discount: 10, image: 'https://via.placeholder.com/200', slug: 'samsung-galaxy-s24-ultra', rating: 4.6, reviewsCount: 67, freeShipping: true, installments: { count: 6, value: 299999 } },
];
---

<BaseLayout title={`"${q}" | Lanús Computación`}>
  <div class="ml-container py-4">
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-ml-text-secondary">
        Resultados para <span class="font-semibold text-ml-text">"{q}"</span>: {results.length} productos
      </p>
    </div>
    <ProductGrid products={results} columns={4} />
  </div>
</BaseLayout>
