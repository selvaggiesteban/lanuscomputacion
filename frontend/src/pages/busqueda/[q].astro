---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import Pagination from '../../components/catalog/Pagination.astro';
import { getProducts, getProductCount } from '../../lib/d1';

const { q } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const page = Number(Astro.url.searchParams.get('page') || 1);
const limit = 20;
const offset = (page - 1) * limit;

const [products, total] = await Promise.all([
  getProducts(db, { search: q, limit, offset }),
  getProductCount(db, undefined, undefined).then(async () => {
    const { count } = await db.prepare(
      "SELECT COUNT(*) as count FROM products WHERE status = 'published' AND (title LIKE ? OR brand LIKE ? OR ean LIKE ?)"
    ).bind(`%${q}%`, `%${q}%`, `%${q}%`).first<{ count: number }>() ?? { count: 0 };
    return count;
  }),
]);

const totalPages = Math.ceil(total / limit);
---

<BaseLayout title={`"${q}" | Lanús Computación`}>
  <div class="ml-container py-4">
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm text-ml-text-secondary">
        Resultados para <span class="font-semibold text-ml-text">"{q}"</span>: {total} productos
      </p>
    </div>

    <ProductGrid products={products.map(p => ({
      id: p.id,
      title: p.title,
      price: p.price,
      image: p.thumbnail,
      slug: p.slug,
      freeShipping: false,
    }))} columns={4} />

    <Pagination current={page} total={totalPages} baseUrl={`/busqueda/${q}`} />
  </div>
</BaseLayout>
