---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';

const orderId = Astro.url.searchParams.get('order_id');
---

<BaseLayout title="Compra exitosa | Lanús Computación">
  <div class="ml-container py-8">
    <div class="max-w-lg mx-auto text-center">
      <div class="bg-white rounded shadow-card p-8">
        <div class="w-16 h-16 bg-ml-green-bg rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00a650" stroke-width="3" stroke-linecap="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>

        <h1 class="text-xl font-semibold text-ml-text mb-2">¡Compra exitosa!</h1>
        <p class="text-sm text-ml-text-secondary mb-6">
          Tu pedido se procesó correctamente. Recibirás un email de confirmación en unos minutos.
        </p>

        {orderId && (
          <div class="bg-ml-bg rounded p-4 mb-6">
            <p class="text-xs text-ml-text-muted">Número de pedido</p>
            <p class="text-sm font-mono font-medium text-ml-text">{orderId}</p>
          </div>
        )}

        <div class="space-y-3">
          <a href="/" class="ml-btn-primary w-full inline-block text-center">
            Seguir comprando
          </a>
          {orderId && (
            <a href={`/compras?order=${orderId}`} class="ml-btn-secondary w-full inline-block text-center">
              Ver mi pedido
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
