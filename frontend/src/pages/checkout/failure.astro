---
import BaseLayout from '../../layouts/BaseLayout.astro';

const orderId = Astro.url.searchParams.get('order_id');
---

<BaseLayout title="Pago no completado | Lanús Computación">
  <div class="ml-container py-8">
    <div class="max-w-lg mx-auto text-center">
      <div class="bg-white rounded shadow-card p-8">
        <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e53e3e" stroke-width="3" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </div>

        <h1 class="text-xl font-semibold text-ml-text mb-2">Pago no completado</h1>
        <p class="text-sm text-ml-text-secondary mb-6">
          El pago no se pudo procesar. Podés intentar nuevamente o elegir otro medio de pago.
        </p>

        {orderId && (
          <div class="bg-ml-bg rounded p-4 mb-6">
            <p class="text-xs text-ml-text-muted">Número de pedido</p>
            <p class="text-sm font-mono font-medium text-ml-text">{orderId}</p>
          </div>
        )}

        <div class="space-y-3">
          <a href="/carrito" class="ml-btn-primary w-full inline-block text-center">
            Volver al carrito
          </a>
          <a href="/" class="ml-btn-secondary w-full inline-block text-center">
            Seguir comprando
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
