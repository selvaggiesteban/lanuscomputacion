---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import Pagination from '../../components/catalog/Pagination.astro';
import ActiveFilters from '../../components/catalog/ActiveFilters.astro';
import SortSelector from '../../components/catalog/SortSelector.tsx';
import { getProducts, getProductCount } from '../../lib/d1';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const page = Number(Astro.url.searchParams.get('page') || 1);
const limit = 20;
const offset = (page - 1) * limit;

const [products, total] = await Promise.all([
  getProducts(db, { category: slug, limit, offset }),
  getProductCount(db, slug),
]);

const totalPages = Math.ceil(total / limit);

const categoryName = slug === 'todas' ? 'Todas las categorías' : (products[0]?.category_name || slug);
---

<BaseLayout title={`${categoryName} | Lanús Computación`}>
  <div class="ml-container">
    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: categoryName },
    ]} />
  </div>

  <div class="ml-container flex gap-6">
    <aside class="hidden lg:block w-64 flex-shrink-0">
      <div class="mb-4">
        <h1 class="text-lg font-semibold text-ml-text">{categoryName}</h1>
        <p class="text-xs text-ml-text-muted mt-1">{total} resultados</p>
      </div>
    </aside>

    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-4 bg-white p-3 rounded shadow-card">
        <p class="text-sm text-ml-text-secondary">
          {total} resultados en <span class="font-medium text-ml-text">{categoryName}</span>
        </p>
        <SortSelector client:load />
      </div>

      <ActiveFilters filters={[]} baseUrl={`/categoria/${slug}`} />

      <ProductGrid products={products.map(p => ({
        id: p.id,
        title: p.title,
        price: p.price,
        image: p.thumbnail,
        slug: p.slug,
        freeShipping: false,
      }))} columns={4} />

      <Pagination current={page} total={totalPages} baseUrl={`/categoria/${slug}`} />
    </div>
  </div>
</BaseLayout>
