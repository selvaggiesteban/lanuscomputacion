---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import Pagination from '../../components/catalog/Pagination.astro';
import SortSelector from '../../components/catalog/SortSelector.tsx';
import { getProducts, getProductCount, getCategoryBySlug, getSubcategories, getBrandsByCategory } from '../../lib/d1';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const page = Number(Astro.url.searchParams.get('page') || 1);
const minPrice = Number(Astro.url.searchParams.get('min_price') || 0);
const maxPrice = Number(Astro.url.searchParams.get('max_price') || 0);
const brand = Astro.url.searchParams.get('brand') || '';
const sort = Astro.url.searchParams.get('sort') || '';
const limit = 20;
const offset = (page - 1) * limit;

const category = slug !== 'todas' ? await getCategoryBySlug(db, slug) : null;

const subcategories = category && category.level === 0
  ? await getSubcategories(db, category.id)
  : [];

const categoryFilter = category?.level === 0 ? category.id : undefined;
const subcategoryFilter = category?.level === 1 ? category.name : undefined;

const products = await getProducts(db, {
  category: categoryFilter,
  subcategory: subcategoryFilter,
  brand: brand || undefined,
  sort: sort || undefined,
  limit,
  offset,
  minPrice: minPrice || undefined,
  maxPrice: maxPrice || undefined,
});
const total = await getProductCount(db, categoryFilter, subcategoryFilter, brand || undefined);
const brands = await getBrandsByCategory(db, categoryFilter, subcategoryFilter);

const totalPages = Math.ceil(total / limit);
const categoryName = slug === 'todas' ? 'Todas las categorías' : (category?.name || slug);

// Build base URL for filters
const filterBaseUrl = `/categoria/${slug}`;

// Get price range
const priceRange = await db.prepare(`
  SELECT MIN(price) as min_price, MAX(price) as max_price
  FROM products WHERE status = 'published' AND category_id = ?
`).bind(categoryFilter || '').first<{ min_price: number; max_price: number }>();
---

<BaseLayout title={`${categoryName} | Lanús Computación`}>
  <div class="ml-container">
    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      ...(category?.parent_id ? [{ label: 'Categorías', href: '/categoria/todas' }] : []),
      { label: categoryName },
    ]} />
  </div>

  <div class="ml-container flex gap-6">
    <aside class="hidden lg:block w-64 flex-shrink-0 space-y-4">
      <div>
        <h1 class="text-lg font-semibold text-ml-text">{categoryName}</h1>
        <p class="text-xs text-ml-text-muted mt-1">{total} resultados</p>
      </div>

      {subcategories.length > 0 && (
        <div class="bg-white rounded shadow-card p-4">
          <h3 class="text-sm font-semibold text-ml-text mb-3">Subcategorías</h3>
          <ul class="space-y-2">
            {subcategories.map((sub) => (
              <li>
                <a href={`/categoria/${sub.slug}`}
                   class={`text-sm hover:text-ml-blue transition-colors ${sub.slug === slug ? 'text-ml-blue font-medium' : 'text-ml-text-secondary'}`}>
                  {sub.picture} {sub.name}
                  {sub.total_items > 0 && <span class="text-xs text-ml-text-muted ml-1">({sub.total_items})</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {brands.length > 0 && (
        <div class="bg-white rounded shadow-card p-4">
          <h3 class="text-sm font-semibold text-ml-text mb-3">Marca</h3>
          <ul class="space-y-2 max-h-48 overflow-y-auto">
            {brands.map((b) => (
              <li>
                <a href={`${filterBaseUrl}${brand === b.brand ? '' : `?brand=${encodeURIComponent(b.brand)}`}`}
                   class={`flex items-center justify-between text-sm hover:text-ml-blue transition-colors ${brand === b.brand ? 'text-ml-blue font-medium' : 'text-ml-text-secondary'}`}>
                  <span>{b.brand}</span>
                  <span class="text-xs text-ml-text-muted">({b.count})</span>
                </a>
              </li>
            ))}
          </ul>
          {brand && (
            <a href={filterBaseUrl} class="block mt-3 text-xs text-ml-blue hover:underline">Limpiar marca</a>
          )}
        </div>
      )}

      <div class="bg-white rounded shadow-card p-4">
        <h3 class="text-sm font-semibold text-ml-text mb-3">Precio</h3>
        <form id="price-filter-form" class="space-y-3">
          <div class="flex gap-2 items-center">
            <input type="number" name="min_price" placeholder="Mínimo" value={minPrice || ''}
                   class="ml-input w-full text-sm" min="0" />
            <span class="text-ml-text-muted">-</span>
            <input type="number" name="max_price" placeholder="Máximo" value={maxPrice || ''}
                   class="ml-input w-full text-sm" min="0" />
          </div>
          <button type="submit" class="ml-btn-primary w-full text-sm py-2">Filtrar</button>
          {(minPrice > 0 || maxPrice > 0) && (
            <a href={filterBaseUrl} class="block text-center text-xs text-ml-blue hover:underline">Limpiar filtro</a>
          )}
        </form>
        {priceRange && (
          <p class="text-xs text-ml-text-muted mt-2">
            Rango: ${priceRange.min_price?.toLocaleString('es-AR')} - ${priceRange.max_price?.toLocaleString('es-AR')}
          </p>
        )}
      </div>
    </aside>

    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-4 bg-white p-3 rounded shadow-card">
        <p class="text-sm text-ml-text-secondary">
          {total} resultados en <span class="font-medium text-ml-text">{categoryName}</span>
          {(minPrice > 0 || maxPrice > 0) && (
            <span class="text-ml-text-muted">
              | ${minPrice || 0} - ${maxPrice || '∞'}
            </span>
          )}
        </p>
        <SortSelector client:load current={sort} />
      </div>

      <ProductGrid products={products.map(p => ({
        id: p.id,
        title: p.title,
        price: p.price,
        image: p.thumbnail,
        slug: p.slug,
        freeShipping: false,
      }))} columns={4} />

      <Pagination current={page} total={totalPages} baseUrl={`${filterBaseUrl}${brand ? `?brand=${encodeURIComponent(brand)}` : ''}${minPrice ? `${brand ? '&' : '?'}min_price=${minPrice}` : ''}${maxPrice ? `${brand || minPrice ? '&' : '?'}max_price=${maxPrice}` : ''}`} />
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('price-filter-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const params = new URLSearchParams();
    const urlParams = new URLSearchParams(window.location.search);
    const brand = urlParams.get('brand');
    if (brand) params.set('brand', brand);
    const min = formData.get('min_price') as string;
    const max = formData.get('max_price') as string;
    if (min) params.set('min_price', min);
    if (max) params.set('max_price', max);
    window.location.href = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
  });
</script>
