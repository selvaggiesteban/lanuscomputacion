---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mis compras | Lanús Computación">
  <div class="ml-container py-6">
    <h1 class="text-xl font-semibold text-ml-text mb-6">Mis compras</h1>

    <div class="bg-white rounded shadow-card p-8 text-center text-ml-text-muted">
      <p class="text-lg font-medium text-ml-text mb-2">No tenés compras todavía</p>
      <p class="text-sm mb-6">Tus compras aparecerán acá una vez que realices tu primer pedido</p>
      <a href="/" class="ml-btn-primary inline-block">
        Empezar a comprar
      </a>
    </div>
  </div>
</BaseLayout>
