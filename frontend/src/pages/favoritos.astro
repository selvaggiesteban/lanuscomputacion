---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/catalog/ProductGrid.astro';

const favorites = [
  { id: '1', title: 'iPhone 15 Pro Max 256GB', price: 2199999, originalPrice: 2499999, discount: 12, image: 'https://via.placeholder.com/200', slug: 'iphone-15-pro-max', rating: 4.7, reviewsCount: 89, freeShipping: true, installments: { count: 6, value: 366666 } },
  { id: '2', title: 'MacBook Air M3 15"', price: 2399999, originalPrice: 2699999, discount: 11, image: 'https://via.placeholder.com/200', slug: 'macbook-air-m3-15', rating: 4.8, reviewsCount: 45, freeShipping: true, installments: { count: 6, value: 399999 } },
];
---

<BaseLayout title="Favoritos | Lanús Computación">
  <div class="ml-container py-6">
    <h1 class="text-xl font-semibold text-ml-text mb-6">Mis favoritos</h1>
    <ProductGrid products={favorites} columns={4} />
  </div>
</BaseLayout>
