---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/catalog/ProductGrid.astro';
import { getProducts } from '../lib/d1';

const db = Astro.locals.runtime.env.DB;

// Get products sorted by discount (cost_price vs price ratio) as proxy for "ofertas"
const { results: offerProducts } = await db.prepare(`
  SELECT * FROM products
  WHERE status = 'published' AND cost_price > 0 AND available_qty > 0
  ORDER BY (price - cost_price) / cost_price DESC
  LIMIT 20
`).all();
---

<BaseLayout title="Ofertas | Lanús Computación">
  <div class="ml-container py-4">
    <div class="bg-gradient-to-r from-red-50 to-orange-50 rounded-lg p-6 mb-6">
      <h1 class="text-2xl font-bold text-ml-text mb-1">Ofertas</h1>
      <p class="text-sm text-ml-text-secondary">Los mejores descuentos en tecnología</p>
    </div>

    {offerProducts.length > 0 ? (
      <ProductGrid products={offerProducts.map(p => ({
        id: p.id,
        title: p.title,
        price: p.price,
        originalPrice: p.cost_price,
        image: p.thumbnail,
        slug: p.slug,
        freeShipping: false,
      }))} columns={5} />
    ) : (
      <div class="text-center py-16 text-ml-text-muted">
        <p class="text-lg">No hay ofertas disponibles</p>
        <p class="text-sm mt-1">Volvé pronto para ver los mejores descuentos</p>
      </div>
    )}
  </div>
</BaseLayout>
