---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Price from '../../components/ui/Price.astro';
import Badge from '../../components/ui/Badge.astro';
import Rating from '../../components/ui/Rating.astro';
import ShareButtons from '../../components/ui/ShareButtons.astro';
import AddToCartButton from '../../components/cart/AddToCartButton.tsx';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import { getProductBySlug, getProducts } from '../../lib/d1';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const product = await getProductBySlug(db, slug!);

if (!product) {
  return Astro.redirect('/404');
}

const relatedProducts = (await getProducts(db, { limit: 5 }))
  .filter(p => p.slug !== slug);
---

<BaseLayout title={`${product.title} | Lanús Computación`}>
  <!-- Schema.org Product -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.title,
    description: product.description,
    image: product.thumbnail,
    sku: product.sku || product.external_id,
    gtin13: product.ean || undefined,
    brand: product.brand ? { "@type": "Brand", name: product.brand } : undefined,
    offers: {
      "@type": "Offer",
      priceCurrency: "ARS",
      price: product.price,
      availability: product.available_qty > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
      seller: {
        "@type": "Organization",
        name: "Lanús Computación"
      }
    }
  })} />

  <div class="ml-container">
    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: product.category_name || 'Categoria', href: `/categoria/${product.category_name?.toLowerCase().replace(/[^a-z0-9]+/g, "-")}` },
      { label: product.title },
    ]} />
  </div>

  <div class="ml-container py-4">
    <div class="bg-white rounded shadow-card p-4 md:p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="aspect-square bg-ml-bg rounded-lg flex items-center justify-center overflow-hidden mb-3">
            <img
              src={product.thumbnail}
              alt={product.title}
              class="object-contain w-3/4 h-3/4 hover:scale-110 transition-transform duration-500"
            />
          </div>
        </div>

        <div>
          <div class="flex items-center gap-2 text-xs text-ml-text-muted mb-2">
            <span>Nuevo</span>
            <span>|</span>
            <span>{product.provider_store === 'mayorista' ? 'Mayorista' : 'Minorista'}</span>
          </div>

          <h1 class="text-lg md:text-xl font-medium text-ml-text mb-3 leading-snug">
            {product.title}
          </h1>

          {product.brand && (
            <p class="text-sm text-ml-text-muted mb-3">Marca: {product.brand}</p>
          )}

          <div class="mb-6">
            <Price
              price={product.price}
              size="lg"
            />
            {product.dollar_rate > 0 && (
              <p class="text-xs text-ml-text-muted mt-1">
                Cotización USD: ${product.dollar_rate.toFixed(2)}
              </p>
            )}
          </div>

          <div class="border rounded-lg p-4 mb-4">
            <h3 class="text-sm font-medium text-ml-text mb-2">Calcular envío</h3>
            <div class="flex gap-2">
              <input
                type="text"
                placeholder="Código postal"
                class="ml-input flex-1 uppercase"
                maxlength="8"
              />
              <button class="ml-btn-primary text-sm px-4 py-2 whitespace-nowrap">
                Calcular
              </button>
            </div>
          </div>

          <p class="text-xs text-ml-green font-medium mb-4">
            Stock disponible: {product.available_qty} unidades
          </p>

          <AddToCartButton
            client:load
            productId={product.id}
            title={product.title}
            price={product.price}
            thumbnail={product.thumbnail}
            slug={product.slug}
            availableQty={product.available_qty}
          />

          <a href={`/producto/${product.slug}`} class="ml-btn-primary w-full text-base py-4 flex items-center justify-center gap-2 mt-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1" />
              <circle cx="20" cy="21" r="1" />
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
            </svg>
            Comprar ahora
          </a>

          <div class="mt-4">
            <ShareButtons title={product.title} url={`https://lanuscomputacion.com/producto/${product.slug}`} price={product.price} />
          </div>

          <div class="border-t mt-6 pt-4">
            <h3 class="text-sm font-medium text-ml-text mb-2">Medios de pago</h3>
            <div class="flex flex-wrap gap-4 text-xs text-ml-text-secondary">
              <div class="flex items-center gap-1">
                <span class="text-ml-blue font-bold text-sm">MP</span>
                Mercado Pago
              </div>
              <div class="flex items-center gap-1">
                <span class="text-b2b-purple font-bold text-sm">BT</span>
                Transferencia bancaria
              </div>
            </div>
          </div>
        </div>
      </div>

      {product.description && (
        <div class="border-t mt-8 pt-6">
          <h2 class="text-lg font-medium text-ml-text mb-3">Descripción</h2>
          <p class="text-sm text-ml-text-secondary leading-relaxed max-w-2xl">
            {product.description}
          </p>
        </div>
      )}

      <div class="border-t mt-8 pt-6">
        <h2 class="text-lg font-medium text-ml-text mb-3">Características</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-w-2xl">
          {[
            { label: 'Marca', value: product.brand || '-' },
            { label: 'EAN', value: product.ean || '-' },
            { label: 'Stock', value: `${product.available_qty} unidades` },
            { label: 'Tipo', value: product.provider_store === 'mayorista' ? 'Mayorista' : 'Minorista' },
          ].filter(a => a.value !== '-').map(attr => (
            <div class="flex items-center border-b pb-2">
              <span class="text-sm text-ml-text-muted w-28 flex-shrink-0">{attr.label}</span>
              <span class="text-sm text-ml-text">{attr.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="text-lg font-medium text-ml-text mb-4">Reseñas</h2>
      <div id="reviews-section" class="bg-white rounded shadow-card p-4">
        <div id="reviews-loading" class="text-sm text-ml-text-muted py-4">Cargando reseñas...</div>
        <div id="reviews-list" class="space-y-4 hidden"></div>
        <div id="no-reviews" class="text-sm text-ml-text-muted py-4 hidden">No hay reseñas aún. ¡Sé el primero en reseñar!</div>

        <div class="border-t mt-4 pt-4">
          <h3 class="text-sm font-medium text-ml-text mb-3">Dejá tu reseña</h3>
          <div id="review-login-msg" class="text-sm text-ml-text-muted mb-3 hidden">
            <a href="/login" class="ml-link">Iniciá sesión</a> para reseñar.
          </div>
          <form id="review-form" class="space-y-3">
            <div>
              <label class="text-xs text-ml-text-muted">Puntuación *</label>
              <div class="flex gap-1 mt-1" id="star-rating">
                {[1,2,3,4,5].map(n => (
                  <button type="button" data-rating={n} class="star-btn text-2xl text-gray-300 hover:text-yellow-400 transition-colors">★</button>
                ))}
              </div>
            </div>
            <input type="hidden" name="rating" id="rating-input" value="0" />
            <input type="text" name="title" placeholder="Título (opcional)" class="ml-input w-full" />
            <textarea name="comment" placeholder="Tu reseña (opcional)" class="ml-input w-full" rows="3"></textarea>
            <button type="submit" class="ml-btn-primary text-sm px-4 py-2">Enviar reseña</button>
          </form>
        </div>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-lg font-medium text-ml-text mb-4">Productos relacionados</h2>
      <ProductGrid products={relatedProducts.map(p => ({
        id: p.id,
        title: p.title,
        price: p.price,
        image: p.thumbnail,
        slug: p.slug,
        freeShipping: false,
      }))} columns={5} />
    </section>
  </div>
</BaseLayout>

<script define:vars={{ productId: product.id }}>
  const reviewForm = document.getElementById('review-form');
  const reviewsList = document.getElementById('reviews-list');
  const reviewsLoading = document.getElementById('reviews-loading');
  const noReviews = document.getElementById('no-reviews');
  const reviewLoginMsg = document.getElementById('review-login-msg');
  const ratingInput = document.getElementById('rating-input');
  const starBtns = document.querySelectorAll('.star-btn');

  // Star rating
  let selectedRating = 0;
  starBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedRating = Number(btn.dataset.rating);
      ratingInput.value = selectedRating;
      starBtns.forEach((s, i) => {
        s.classList.toggle('text-yellow-400', i < selectedRating);
        s.classList.toggle('text-gray-300', i >= selectedRating);
      });
    });
  });

  // Load reviews
  async function loadReviews() {
    try {
      const res = await fetch(`/api/reviews?product_id=${productId}`);
      const data = await res.json();
      reviewsLoading.classList.add('hidden');

      if (data.reviews.length === 0) {
        noReviews.classList.remove('hidden');
        return;
      }

      const stars = (n) => '★'.repeat(n) + '☆'.repeat(5 - n);
      reviewsList.innerHTML = data.reviews.map(r => `
        <div class="border-b pb-3">
          <div class="flex items-center gap-2">
            <span class="text-yellow-500 text-sm">${stars(r.rating)}</span>
            <span class="text-sm font-medium text-ml-text">${r.title || ''}</span>
            ${r.is_verified ? '<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">Compra verificada</span>' : ''}
          </div>
          <p class="text-xs text-ml-text-muted mt-1">${r.customer_name} · ${new Date(r.created_at).toLocaleDateString('es-AR')}</p>
          ${r.comment ? `<p class="text-sm text-ml-text-secondary mt-2">${r.comment}</p>` : ''}
        </div>
      `).join('');
      reviewsList.classList.remove('hidden');

      if (data.stats.count > 0) {
        const header = document.createElement('div');
        header.className = 'mb-3 pb-3 border-b';
        header.innerHTML = `<span class="text-sm text-ml-text-muted">${data.stats.count} reseñas · Promedio: <span class="text-yellow-500">${Number(data.stats.avg_rating).toFixed(1)}</span>/5</span>`;
        reviewsList.prepend(header);
      }
    } catch {
      reviewsLoading.textContent = 'Error al cargar reseñas';
    }
  }

  loadReviews();

  // Submit review
  reviewForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (selectedRating === 0) {
      alert('Seleccioná una puntuación');
      return;
    }

    const formData = new FormData(reviewForm);
    try {
      const res = await fetch('/api/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          product_id: productId,
          rating: selectedRating,
          title: formData.get('title') || null,
          comment: formData.get('comment') || null,
        }),
      });

      const data = await res.json();
      if (!res.ok) {
        if (res.status === 401) {
          reviewLoginMsg.classList.remove('hidden');
        } else {
          alert(data.error || 'Error al enviar reseña');
        }
        return;
      }

      reviewForm.reset();
      selectedRating = 0;
      ratingInput.value = 0;
      starBtns.forEach(s => { s.classList.remove('text-yellow-400'); s.classList.add('text-gray-300'); });
      loadReviews();
    } catch {
      alert('Error de conexión');
    }
  });
</script>
