---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Price from '../../components/ui/Price.astro';
import Badge from '../../components/ui/Badge.astro';
import Rating from '../../components/ui/Rating.astro';
import Button from '../../components/ui/Button.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import products from '../../data/products.json';

export async function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}
const { product } = Astro.props;
const relatedProducts = products.filter(p => p.slug !== product.slug).slice(0, 5);
---

<BaseLayout title={`${product.title} | Lanús Computación`}>
  <div class="ml-container">
    <Breadcrumb items={[
      { label: 'Inicio', href: '/' },
      { label: product.categorySlug || 'Categoria', href: `/categoria/${product.categorySlug}` },
      { label: product.title },
    ]} />
  </div>

  <div class="ml-container py-4">
    <div class="bg-white rounded shadow-card p-4 md:p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Image Gallery -->
        <div>
          <div class="aspect-square bg-ml-bg rounded-lg flex items-center justify-center overflow-hidden mb-3">
            <img
              src={product.image}
              alt={product.title}
              class="object-contain w-3/4 h-3/4 hover:scale-110 transition-transform duration-500"
            />
          </div>
          <div class="flex gap-2">
            {[1, 2, 3, 4].map(i => (
              <button class="w-14 h-14 border-2 rounded overflow-hidden hover:border-ml-blue transition-colors">
                <div class="w-full h-full bg-ml-bg flex items-center justify-center text-xs text-ml-text-muted">
                  {i}
                </div>
              </button>
            ))}
          </div>
        </div>

        <!-- Product Info -->
        <div>
          <div class="flex items-center gap-2 text-xs text-ml-text-muted mb-2">
            <span>{product.condition || 'Nuevo'}</span>
            <span>|</span>
            <span>{product.soldQuantity?.toLocaleString()} vendidos</span>
          </div>

          <h1 class="text-lg md:text-xl font-medium text-ml-text mb-3 leading-snug">
            {product.title}
          </h1>

          {product.rating && (
            <div class="mb-3">
              <Rating rating={product.rating} count={product.reviewsCount} />
            </div>
          )}

          <div class="flex flex-wrap gap-1 mb-4">
            {product.freeShipping && <Badge variant="free_shipping" />}
            {product.b2bPrice && <Badge variant="b2b" />}
          </div>

          <!-- Price -->
          <div class="mb-6">
            <Price
              price={product.price}
              originalPrice={product.originalPrice}
              discount={product.discount}
              installments={product.installments}
              size="lg"
            />
          </div>

          <!-- B2B Toggle -->
          {product.b2bPrice && (
            <div class="bg-b2b-purple-light rounded-lg p-4 mb-6">
              <label class="flex items-center justify-between cursor-pointer">
                <div>
                  <p class="font-semibold text-b2b-purple text-sm">Precio mayorista</p>
                  <p class="text-xs text-b2b-purple/70">Disponible para empresas registradas</p>
                </div>
                <div class="text-right">
                  <span class="text-price-md font-bold text-b2b-purple">
                    ${product.b2bPrice.toLocaleString('es-AR')}
                  </span>
                  <p class="text-xs text-ml-green font-medium">
                    Ahorras ${(product.price - product.b2bPrice).toLocaleString('es-AR')}
                  </p>
                </div>
              </label>
            </div>
          )}

          <!-- Shipping calculator -->
          <div class="border rounded-lg p-4 mb-4">
            <h3 class="text-sm font-medium text-ml-text mb-2">Calcular envio</h3>
            <div class="flex gap-2">
              <input
                type="text"
                placeholder="Codigo postal"
                class="ml-input flex-1 uppercase"
                maxlength="8"
              />
              <button class="ml-btn-primary text-sm px-4 py-2 whitespace-nowrap">
                Calcular
              </button>
            </div>
            {product.freeShipping && (
              <p class="text-xs text-ml-green mt-2 flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Envio gratis a todo el pais
              </p>
            )}
          </div>

          <!-- Stock -->
          <p class="text-xs text-ml-green font-medium mb-4">
            Stock disponible: {product.availableQuantity} unidades
          </p>

          <!-- Actions -->
          <div class="flex flex-col gap-3">
            <button class="ml-btn-primary w-full text-base py-4 flex items-center justify-center gap-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
              </svg>
              Comprar ahora
            </button>
            <button class="ml-btn-secondary w-full text-base py-4 flex items-center justify-center gap-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12h14" />
              </svg>
              Agregar al carrito
            </button>
            <button class="flex items-center justify-center gap-2 text-sm text-ml-text-secondary hover:text-red-500 transition-colors py-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              </svg>
              Agregar a favoritos
            </button>
          </div>

          {product.b2bPrice && (
            <div class="mt-4 text-center">
              <a href="/b2b" class="text-xs ml-link">
                Queres este producto a precio mayorista? Registrate aca
              </a>
            </div>
          )}

          <div class="border-t mt-6 pt-4">
            <h3 class="text-sm font-medium text-ml-text mb-2">Medios de pago</h3>
            <div class="flex flex-wrap gap-4 text-xs text-ml-text-secondary">
              <div class="flex items-center gap-1">
                <span class="text-ml-blue font-bold text-sm">MP</span>
                Mercado Pago
              </div>
              <div class="flex items-center gap-1">
                <span class="text-b2b-purple font-bold text-sm">BT</span>
                Transferencia bancaria
              </div>
            </div>
          </div>
        </div>
      </div>

      {product.description && (
        <div class="border-t mt-8 pt-6">
          <h2 class="text-lg font-medium text-ml-text mb-3">Descripcion</h2>
          <p class="text-sm text-ml-text-secondary leading-relaxed max-w-2xl">
            {product.description}
          </p>
        </div>
      )}

      <div class="border-t mt-8 pt-6">
        <h2 class="text-lg font-medium text-ml-text mb-3">Caracteristicas</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-w-2xl">
          {[
            { label: 'Marca', value: product.title.split(' ')[0] },
            { label: 'Condicion', value: product.condition || 'Nuevo' },
            { label: 'Vendidos', value: product.soldQuantity?.toLocaleString() || '-' },
            { label: 'Stock', value: `${product.availableQuantity || 0} unidades` },
          ].map(attr => (
            <div class="flex items-center border-b pb-2">
              <span class="text-sm text-ml-text-muted w-28 flex-shrink-0">{attr.label}</span>
              <span class="text-sm text-ml-text">{attr.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="text-lg font-medium text-ml-text mb-4">Productos relacionados</h2>
      <ProductGrid products={relatedProducts} columns={5} />
    </section>
  </div>
</BaseLayout>
