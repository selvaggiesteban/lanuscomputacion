---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mayorista B2B | Lanús Computación">
  <div class="ml-container py-8">
    <div class="max-w-2xl mx-auto">
      <div class="bg-white rounded shadow-card p-8">
        <div class="text-center mb-6">
          <h1 class="text-2xl font-bold text-b2b-purple mb-2">Lanús Computación Mayorista</h1>
          <p class="text-ml-text-secondary">
            Precios especiales para empresas, revendedores y emprendedores.
          </p>
        </div>

        <div class="space-y-4 mb-8">
          {[
            { title: 'Descuentos por volumen', desc: 'Mejores precios en compras al por mayor' },
            { title: 'Atención personalizada', desc: 'Ejecutivo de cuentas dedicado' },
            { title: 'Facturación A y B', desc: 'Factura electrónica para tu empresa' },
            { title: 'Múltiples medios de pago', desc: 'Transferencia bancaria, MP, cheques' },
          ].map(benefit => (
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-ml-green-bg rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00a650" stroke-width="3" stroke-linecap="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-medium text-ml-text">{benefit.title}</h3>
                <p class="text-xs text-ml-text-muted">{benefit.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div id="success-message" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded text-sm text-green-700"></div>
        <div id="error-message" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded text-sm text-red-700"></div>

        <form id="b2b-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-ml-text-muted mb-1">Nombre completo</label>
              <input type="text" name="name" class="ml-input w-full" required />
            </div>
            <div>
              <label class="block text-xs text-ml-text-muted mb-1">Empresa</label>
              <input type="text" name="company" class="ml-input w-full" required />
            </div>
            <div>
              <label class="block text-xs text-ml-text-muted mb-1">Email corporativo</label>
              <input type="email" name="email" class="ml-input w-full" required />
            </div>
            <div>
              <label class="block text-xs text-ml-text-muted mb-1">Teléfono</label>
              <input type="tel" name="phone" class="ml-input w-full" required />
            </div>
          </div>
          <div>
            <label class="block text-xs text-ml-text-muted mb-1">CUIT</label>
            <input type="text" name="cuit" class="ml-input w-full" placeholder="XX-XXXXXXXX-X" required />
          </div>
          <button type="submit" class="bg-b2b-purple text-white font-bold py-3 px-8 rounded w-full hover:bg-purple-700 transition-colors">
            Solicitar registro mayorista
          </button>
        </form>

        <p class="text-center mt-4 text-xs text-ml-text-muted">
          Te contactaremos en 24-48 hs hábiles para activar tu cuenta mayorista.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('b2b-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message')!;
  const successDiv = document.getElementById('success-message')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');

    const formData = new FormData(form);

    try {
      const res = await fetch('/api/b2b/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: formData.get('name'),
          company: formData.get('company'),
          email: formData.get('email'),
          phone: formData.get('phone'),
          cuit: formData.get('cuit'),
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorDiv.textContent = data.error || 'Error al enviar solicitud';
        errorDiv.classList.remove('hidden');
        return;
      }

      successDiv.textContent = data.message || 'Solicitud enviada correctamente';
      successDiv.classList.remove('hidden');
      form.reset();
    } catch (err) {
      errorDiv.textContent = 'Error de conexión';
      errorDiv.classList.remove('hidden');
    }
  });
</script>
