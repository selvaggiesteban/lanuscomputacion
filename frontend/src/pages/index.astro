---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/catalog/ProductGrid.astro';
import { getProducts, getCategories } from '../lib/d1';

const db = Astro.locals.runtime.env.DB;
const featuredProducts = await getProducts(db, { limit: 10 });
const categories = await getCategories(db);
---

<BaseLayout title="Lanús Computación - Tecnología al mejor precio">
  <section class="bg-gradient-to-r from-ml-yellow to-yellow-200">
    <div class="ml-container py-8 md:py-12">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-4xl font-bold text-ml-text mb-3">
          Tecnología al mejor precio
        </h1>
        <p class="text-lg text-ml-text-secondary mb-6">
          Encontrá todo en celulares, computación, audio, gaming y más. 
          <span class="text-b2b-purple font-semibold">Precios especiales para empresas.</span>
        </p>
        <div class="flex gap-3">
          <a href="/categoria/todas" class="ml-btn-primary">
            Ver catálogo
          </a>
          <a href="/ofertas" class="ml-btn-secondary">
            Ofertas
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="ml-container py-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-ml-text">Categorías</h2>
      <a href="/categoria/todas" class="text-sm ml-link">Ver todas</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {categories.slice(0, 8).map((cat) => (
        <a
          href={`/categoria/${cat.slug}`}
          class="ml-card p-4 flex items-center gap-3 hover:border-ml-blue hover:shadow-card-hover transition-all"
        >
          <div class="w-14 h-14 bg-ml-bg rounded flex items-center justify-center flex-shrink-0">
            <span class="text-2xl">{cat.picture || ''}</span>
          </div>
          <div>
            <h3 class="text-sm font-medium text-ml-text">{cat.name}</h3>
            {cat.total_items > 0 && (
              <p class="text-xs text-ml-text-muted">{cat.total_items} productos</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="ml-container py-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-ml-text">Productos destacados</h2>
      <a href="/categoria/todas" class="text-sm ml-link">Ver más</a>
    </div>
    <ProductGrid products={featuredProducts.map(p => ({
      id: p.id,
      title: p.title,
      price: p.price,
      image: p.thumbnail,
      slug: p.slug,
      freeShipping: false,
    }))} columns={5} />
  </section>

  <section class="ml-container py-8">
    <div class="bg-b2b-purple text-white rounded-lg p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>
        <h2 class="text-xl md:text-2xl font-bold mb-1">Comprá al por mayor</h2>
        <p class="opacity-90 text-sm">Descuentos exclusivos para empresas. Registrate sin costo.</p>
      </div>
      <a href="/b2b" class="bg-white text-b2b-purple font-bold px-6 py-3 rounded hover:bg-purple-50 transition-colors whitespace-nowrap">
        Quiero ser mayorista
      </a>
    </div>
  </section>
</BaseLayout>
